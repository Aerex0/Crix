LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Tavily for web search
TAVILY_API_KEY=

# ========================================
# Browser Automation LLM Configuration
# ========================================
# Browser-use needs an LLM API key (cannot use LiveKit's managed LLM)
# Configure ONE of the following:

# Option 1: OpenAI (Recommended - most tested)
# OPENAI_API_KEY=sk-...
# BROWSER_USE_OPENAI_MODEL=gpt-4o-mini  # or gpt-4o

# Option 2: Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-...
# BROWSER_USE_ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Option 3: Google Gemini
# GOOGLE_API_KEY=...
# BROWSER_USE_GOOGLE_MODEL=gemini-2.0-flash-exp

# Option 4: Ollama (Local, Free)
# OLLAMA_MODEL=llama2  # or llama3, mistral, etc.

# ========================================
# Browser Profile Configuration
# ========================================
# Chrome profile to use (preserves logins)
# Run: ls ~/.config/google-chrome/ to see available profiles
CRIX_CHROME_PROFILE=Default  # or Profile 1, Profile 2, etc.

# ========================================
# Memory Configuration
# ========================================
# Persistent memory for preferences, routines, and session continuity
CRIX_MEMORY_ENABLED=true
CRIX_MEMORY_FILE=MEMORY.md
CRIX_MEMORY_DIR=memory
CRIX_MEMORY_MAX_CONTEXT_CHARS=3500
CRIX_MEMORY_SEARCH_LIMIT=5
CRIX_MEMORY_FLUSH_ENABLED=true

# ========================================
# Wake Word Configuration
# ========================================
# Always-on wake word detection (say "hey crix" to activate)
CRIX_WAKEWORD_ENABLED=true
CRIX_WAKEWORD_MODEL_PATH=models/hey_crix.onnx
CRIX_WAKEWORD_THRESHOLD=0.5
CRIX_WAKEWORD_DEBOUNCE=2.0
